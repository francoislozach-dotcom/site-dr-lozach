# ============================================================
#  Cache & Performance — drlozach.fr
# ============================================================

# Activer la compression Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache long sur les assets statiques
<IfModule mod_expires.c>
  ExpiresActive On

  # Images WebP — 1 an
  ExpiresByType image/webp       "access plus 1 year"
  ExpiresByType image/jpeg       "access plus 1 year"
  ExpiresByType image/png        "access plus 1 year"
  ExpiresByType image/svg+xml    "access plus 1 year"
  ExpiresByType video/mp4        "access plus 1 year"

  # CSS & JS — 1 mois (versionnés via ?v= dans les HTML)
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript   "access plus 1 month"

  # HTML — 1 heure
  ExpiresByType text/html  "access plus 1 hour"

  # Fonts
  ExpiresByType font/woff2  "access plus 1 year"
  ExpiresByType font/woff   "access plus 1 year"
</IfModule>

# Cache-Control headers
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|mp4|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Vendor JS (React 18.3.1) — immuable, cache 1 an
  <FilesMatch "^(react|react-dom)\.production\.min\.js$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# Sécurité de base
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# WebP : servir webp si supporté (fallback jpg/png si non)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} \.(jpe?g|png)$
  RewriteCond %{REQUEST_FILENAME}.webp -f
  RewriteRule ^ %{REQUEST_URI}.webp [T=image/webp,L]
</IfModule>
